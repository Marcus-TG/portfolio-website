---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';

const sections = ['home', 'projects', 'about', 'contact'];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Marcus Strauss</title>
  </head>
  <body class="overflow-hidden">

    <!-- Persistent background layer — Three.js canvas will be mounted here -->
    <div id="background" class="fixed inset-0 z-0"></div>

    <!-- Scrim — subtle dark overlay for legibility over shader blooms -->
    <div class="fixed inset-0 z-[1] pointer-events-none" style="background: rgba(14, 14, 14, 0.35)"></div>

    <!-- Black mask outside page frame -->
    <div class="fixed inset-0 z-[2] pointer-events-none border-[3rem] border-black"></div>

    <!-- Page frame — decorative border inset from all four edges -->
    <div id="page-frame" class="fixed inset-12 border border-text-primary pointer-events-none z-50"></div>

    <!-- Sidebar navigation -->
    <Nav />

    <!-- Content area — sections swap here -->
    <main id="content-area" class="fixed top-12 right-12 bottom-12 left-[196px] z-10 overflow-hidden">

      <!-- Home -->
      <section
        id="home"
        class="section absolute inset-0 opacity-0 pointer-events-none"
      >
      <p class="absolute bottom-12 right-12 text-sm tracking-wide text-text-primary text-right leading-relaxed">
        I got into this<br>
        because complex things<br>
        didn't have to be.<br>
        <br>
        A solution you can repeat<br>
        is worth more<br>
        than one you can't explain.<br>
        <br>
        I build for the next person —<br>
        even when that person<br>
        is me.
      </p>
      </section>

      <!-- Projects -->
      <Projects />

      <!-- About -->
      <About />

      <!-- Other sections -->
      {sections.filter(id => !['home', 'about', 'projects'].includes(id)).map(id => (
        <section
          id={id}
          class="section absolute inset-0 flex items-center justify-center opacity-0 pointer-events-none"
        >
          <h1 class="text-4xl font-light tracking-widest uppercase text-text-primary">
            {id.charAt(0).toUpperCase() + id.slice(1)}
          </h1>
        </section>
      ))}
    </main>

  </body>
</html>

<script>
  import { BackgroundScene } from '../background/BackgroundScene.js';
  import gsap from 'gsap';
  import { initTitleCycler } from '../scripts/titleCycler';

  const DURATION = 0.4;

  function getTargetSection(): string {
    const hash = window.location.hash.slice(1);
    const valid = ['home', 'projects', 'about', 'contact'];
    return valid.includes(hash) ? hash : 'home';
  }

  function activateSection(id: string): void {
    const sections = document.querySelectorAll<HTMLElement>('.section');
    const links = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

    // Fade out all sections, fade in the target
    sections.forEach(section => {
      if (section.id === id) {
        gsap.to(section, {
          opacity: 1,
          duration: DURATION,
          ease: 'power2.inOut',
          onStart: () => section.classList.remove('pointer-events-none'),
        });
      } else {
        gsap.to(section, {
          opacity: 0,
          duration: DURATION,
          ease: 'power2.inOut',
          onComplete: () => section.classList.add('pointer-events-none'),
        });
      }
    });

    // Update active link
    links.forEach(link => {
      link.classList.toggle('active', link.dataset.section === id);
    });
  }

  // Background
  const bgContainer = document.getElementById('background')!;
  new BackgroundScene(bgContainer);

  // Initial render — no animation, just show the right section
  function init(): void {
    const target = getTargetSection();

    // Snap the target section visible immediately
    const targetEl = document.getElementById(target);
    if (targetEl) {
      targetEl.style.opacity = '1';
      targetEl.classList.remove('pointer-events-none');
    }

    // Mark the active nav link
    document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
      link.classList.toggle('active', link.dataset.section === target);
    });

    // Sync URL if hash was missing or invalid
    if (window.location.hash.slice(1) !== target) {
      history.replaceState(null, '', `#${target}`);
    }
  }

  // Hash-based routing
  window.addEventListener('hashchange', () => {
    activateSection(getTargetSection());
  });

  // Intercept nav clicks to let GSAP handle the crossfade before the hash updates
  document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      const target = link.dataset.section!;
      if (window.location.hash.slice(1) === target) return; // already here
      history.pushState(null, '', `#${target}`);
      activateSection(target);
    });
  });

  init();
  initTitleCycler();
</script>
