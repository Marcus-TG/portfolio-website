---
const items = [
  'infrastructure that scales.',
  'systems that think.',
  'automation pipelines.',
  'private cloud environments.',
  'retrieval-augmented AI systems.',
  'distributed service architectures.',
  'resilient networks.',
  'event-driven workflows.',
  'AI integration layers.',
  'production-grade deployments.',
  'systems that run while you sleep.',
];
---

<section
  id="about"
  class="section absolute inset-0 opacity-0 pointer-events-none"
>
  <div class="about-scroll" id="about-scroll">
    <div class="about-layout">
      <div class="about-sticky">
        <h2 class="about-heading">I build</h2>
      </div>
      <ul class="about-list" role="list">
        {items.map(item => (
          <li class="about-item">{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .about-scroll {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    overflow-x: hidden;
  }

  .about-layout {
    display: flex;
    align-items: flex-start;
    min-height: 100%;
    padding-inline: clamp(2rem, 5vw, 6rem);
    gap: clamp(2rem, 4vw, 5rem);
  }

  .about-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .about-heading {
    font-size: clamp(2.5rem, 5vw + 1rem, 5rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: #e8e8e8;
    background: linear-gradient(
      to bottom,
      #e8e8e8 40%,
      rgba(232, 232, 232, 0.3)
    );
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    white-space: nowrap;
  }

  .about-list {
    list-style: none;
    margin: 0;
    padding-block: 50vh;
    padding-inline: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25lh;
  }

  .about-item {
    font-size: clamp(2rem, 4vw + 0.5rem, 4.5rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    line-height: 1.2;
    color: #e8e8e8;
    opacity: 0.2;
    transition: opacity 0.3s, color 0.3s;
  }

  /* Scroll-driven highlight */
  @supports (animation-timeline: view()) {
    .about-item {
      animation: highlight linear both;
      animation-timeline: view();
      animation-range: cover calc(50% - 1lh) cover calc(50% + 1lh);
      transition: none;
    }

    @keyframes highlight {
      0% {
        color: #e8e8e8;
        opacity: 0.2;
      }
      50% {
        color: #f3bf32;
        opacity: 1;
      }
      100% {
        color: #e8e8e8;
        opacity: 0.2;
      }
    }
  }

  /* Fallback — no scroll-driven animation support */
  @supports not (animation-timeline: view()) {
    .about-item {
      opacity: 0.85;
      color: #e8e8e8;
    }

    .about-item:hover {
      opacity: 1;
      color: #f3bf32;
    }
  }
</style>
