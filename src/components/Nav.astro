---
const links = [
  { id: 'home',     label: 'Home'     },
  { id: 'projects', label: 'Projects' },
  { id: 'about',    label: 'About'    },
  { id: 'contact',  label: 'Contact'  },
];
---

<nav id="sidebar" class="fixed top-9 left-12 bottom-12 w-44 flex flex-col pt-10 px-8 z-10">

  <!-- Identity -->
  <div class="mb-10">
    <p class="text-text-primary text-5xl font-semibold tracking-wide whitespace-nowrap">Marcus Strauss</p>
    <p id="job-title" class="text-text-primary/50 text-base tracking-widest uppercase mt-2 whitespace-nowrap opacity-0">Systems Administrator</p>
  </div>

  <!-- Navigation -->
  <ul class="flex flex-col gap-6 list-none m-0 p-0">
    {links.map(link => (
      <li>
        <a
          href={`#${link.id}`}
          class="nav-link block text-sm tracking-widest uppercase text-text-primary transition-colors duration-200 hover:text-accent-tertiary"
          data-section={link.id}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

</nav>

<style>
  .nav-link.active {
    color: var(--color-accent-primary);
  }
</style>
